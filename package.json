{
  "name": "project-index",
  "version": "0.1.3",
  "description": "A local-first developer tool that generates machine-readable semantic repository indexes optimized for AI coding assistants.",
  "type": "module",
  "bin": {
    "project-index": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "development": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "project-index",
    "repository-scanner",
    "ai-coding",
    "semantic-index",
    "code-analysis",
    "typescript-parser",
    "python-parser",
    "code-navigation",
    "symbol-registry",
    "ai-agent"
  ],
  "author": "damameet14",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damameet14/project-index.git"
  },
  "homepage": "https://github.com/damameet14/project-index#readme",
  "bugs": {
    "url": "https://github.com/damameet14/project-index/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "ignore": "^6.0.0",
    "ora": "^8.0.0",
    "sql.js": "^1.11.0",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^24.0.0",
    "web-tree-sitter": "^0.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.9",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}